# Example testnet credentials configuration
# Copy this file to testnet_credentials.env and update with your actual credentials
# Or use the run_analysis.sh script which will prompt for credentials

export BINANCE_TESTNET_FIX_KEY="your_testnet_fix_api_key_here"
export BINANCE_TESTNET_FIX_PRIVATE_KEY_PATH="/path/to/your/testnet_private_key.pem"

# These are set automatically by run_analysis.sh (hardcoded for testnet)
# export BINANCE_TESTNET_ENDPOINT="tcp+tls://fix-oe.testnet.binance.vision:9000"
# export BINANCE_TESTNET_SENDER_COMP_ID="TESTCLI"
# export BINANCE_TESTNET_TARGET_COMP_ID="SPOT"
